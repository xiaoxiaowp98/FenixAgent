# Required: legacy global API key for acp-link / worker JWT signing.
# Multiple keys can be separated by commas, the first key is used for JWT signing.
RCS_API_KEYS=replace-with-a-long-random-token

# Recommended: public base URL of the RCS server.
# Used by server logs, spawned acp-link instances, and better-auth fallback.
RCS_BASE_URL=http://localhost:3000

# Optional: explicit Better Auth URL.
# If unset, the server falls back to BETTER_AUTH_URL -> RCS_BASE_URL -> http://localhost:${RCS_PORT}.
# BETTER_AUTH_URL=http://localhost:3000

# Optional: server listen address.
RCS_HOST=0.0.0.0
RCS_PORT=3000

# Optional: CORS allowed origins. Use "*" or comma-separated origins.
# RCS_CORS_ORIGIN=*

# Optional: Better Auth trusted origins. Defaults include localhost dev and RCS_BASE_URL/BETTER_AUTH_URL.
# Add comma-separated frontend origins here when auth requests come from a separate origin.
# RCS_TRUSTED_ORIGINS=http://localhost:5173

# Required: PostgreSQL connection string.
DATABASE_URL=postgres://rcs:rcs@localhost:5432/rcs


RCS_URL=ws://localhost:3000
RCS_SECRET=rcs-registry-secret
# 这个 id 需要在程序中找
RCS_TENANT_ID=

# hindsight 记忆相关
HINDSIGHT_MCP_URL=http://localhost:9999

# Optional: engine plugin selection and configuration.
# RCS_ENGINE_TYPE=opencode
# RCS_CCB_COMMAND=ccb
# RCS_CCB_ARGS=--acp


# 下面是生成模板需要的环境变量
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1/
OPENAI_MODEL=deepseek-v4-flash