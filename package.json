{
    "name": "mothership",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "bun run src/index.ts",
        "dev:web": "cd web && bunx vite",
        "start": "bun run src/index.ts",
        "db:push": "bunx drizzle-kit push",
        "db:generate": "bunx drizzle-kit generate",
        "db:migrate": "bunx drizzle-kit migrate",
        "build:web": "cd web && bunx vite build",
        "preview:web": "cd web && bunx vite preview",
        "typecheck": "tsc --noEmit",
        "lint": "biome check src/ web/src/",
        "lint:fix": "biome check --write src/ web/src/",
        "format": "biome format --write src/ web/src/",
        "format:check": "biome format src/ web/src/",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "check:deps": "bun run scripts/check-deps.ts"
    },
    "dependencies": {
