{
  "name": "fenix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:web": "cd web && bunx vite",
    "start": "bun run src/index.ts",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "build:web": "cd web && bunx vite build",
    "preview:web": "cd web && bunx vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "cd web && tsc --noEmit",
    "lint": "biome check src/ web/src/ web/components/ packages/",
    "lint:fix": "biome check --write src/ web/src/ web/components/ packages/",
    "format": "biome format --write src/ web/src/ web/components/ packages/",
    "format:check": "biome format src/ web/src/ web/components/ packages/",
    "precheck": "biome format --write src/ web/src/ web/components/ packages/ scripts/ docs/.vitepress/ && biome check --write --linter-enabled=false src/ web/src/ web/components/ packages/ scripts/ docs/.vitepress/ && tsc --noEmit && (cd web && tsc --noEmit) && biome check src/ web/src/ web/components/ packages/ scripts/ docs/.vitepress/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "check:deps": "bun run scripts/check-deps.ts",
    "postinstall": "mkdir -p node_modules/@fenix && ln -sf ../../packages/sdk node_modules/@fenix/sdk 2>/dev/null || true",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.192",
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@better-auth/api-key": "^1.6.11",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "@elysiajs/swagger": "^1.3.1",
    "@hookform/resolvers": "^5.4.0",
    "@keyv/redis": "^5.1.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^2.2.0",
    "@pierre/trees": "^1.0.0-beta.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.168.10",
    "@types/js-yaml": "^4.0.9",
    "@xyflow/react": "^12.10.2",
    "acp-link": "workspace: *",
    "ai": "^6.0.190",
    "better-auth": "^1.6.11",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "drawflow": "^0.0.60",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jsqr": "^1.4.0",
    "keyv": "^5.6.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "node-schedule": "^2.1.1",
    "postgres": "^3.4.9",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/dagre": "^0.7.54",
    "@types/node-schedule": "^2.1.8",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitepress": "^1.6.4"
  }
}
